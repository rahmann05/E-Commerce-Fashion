# ─── Novarium Headless E-Commerce — Root Environment Variables ─────────────────
# Copy this file to .env and fill in your actual values.
# Never commit the .env file.

# ── Supabase (Catalog Engine — Supabase PostgreSQL) ──────────────────────────
# Used by: commerce-service, storefront-web (image URLs), admin-web (image upload)
CORE_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
CORE_DIRECT_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
PUBLIC_SUPABASE_URL=https://[ref].supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Neon (Transaction & Identity Engine — Neon PostgreSQL) ───────────────────
# Used by: admin-service, customer-service
ADMIN_DATABASE_URL=postgresql://[user]:[password]@[host]/[db]?sslmode=require
ADMIN_DIRECT_URL=postgresql://[user]:[password]@[host]/[db]?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Shared secret used for JWT signing across admin-service and customer-service.
JWT_SECRET=change-this-secret-in-production

# ── Midtrans Payment Gateway ──────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=your-midtrans-server-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# ── Production URLs (optional — set when deploying) ──────────────────────────
# Gateway / API
GATEWAY_PROD_URL=https://api.your-domain.com
# Storefront
STOREFRONT_PROD_URL=https://your-storefront.com
# Admin Dashboard
ADMIN_PROD_URL=https://admin.your-domain.com

# ── Port Overrides (optional — defaults shown) ───────────────────────────────
# GATEWAY_PORT=8000
# STOREFRONT_PORT=3000
# ADMIN_DASHBOARD_PORT=4000
